# SentinexFace storage
SENTINEX_DATA_DIR=data/vision
SENTINEX_CHROMA_DIR=data/vision/chroma_db
SENTINEX_CHROMA_COLLECTION=sentinex_face_identities
SENTINEX_CLIP_MODEL=openai/clip-vit-base-patch32

# Detection history
SENTINEX_MONGO_URI=mongodb://localhost:27017
SENTINEX_MONGO_DB=omnistatus
SENTINEX_MONGO_DETECTION_COLLECTION=sentinex_face_rtsp_detections

# Frontend runtime
VITE_SOURCE_MODE=rtsp

# Thresholds / umbrales
# 1) OpenCV/YOLO humano: minimo para considerar que el frame tiene una persona.
# Baja este valor si no detecta humanos; subelo si aparecen falsos positivos.
VITE_OPENCV_HUMAN_THRESHOLD=0.45

# 2) Embedding CLIP/Chroma: minimo para considerar que el patron ya existe.
# Si el score queda bajo este valor, se crea un patron nuevo sin nombre.
VITE_EMBEDDING_MATCH_THRESHOLD=0.60

# Cameras shown in the UI (Prefix with VITE_RTSP_URL_)
VITE_RTSP_URL_CAM1=rtsp://user:password@192.168.X.X:554/cam/realmonitor?channel=1&subtype=0
VITE_RTSP_URL_CAM2=rtsp://user:password@192.168.X.X:554/cam/realmonitor?channel=2&subtype=0
